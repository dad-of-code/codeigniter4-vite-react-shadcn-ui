{
    "name": "dad-of-code/codeigniter4-vite-react-shadcn-ui",
    "description": "CodeIgniter4 Vite React Starter App with ShadCN UI & CodeIgniter4 Shield Auth",
    "license": "MIT",
    "type": "project",
    "homepage": "https://github.com/dad-of-code/codeigniter4-vite-react-shadcn-ui",
    "keywords": [
        "codeigniter4",
        "vite",
        "react",
        "shadcn-ui",
        "tailwindcss",
        "shield",
        "starter"
    ],
    "support": {
        "source": "https://github.com/dad-of-code/codeigniter4-vite-react-shadcn-ui",
        "issues": "https://github.com/dad-of-code/codeigniter4-vite-react-shadcn-ui/issues"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/shield": "^1.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('env', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php spark app:setup"
        ]
    }
}
