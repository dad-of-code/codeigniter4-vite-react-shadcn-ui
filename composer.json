{
    "name": "dad-of-code/codeigniter4-vite-react-starterapp",
    "description": "CodeIgniter4 Vite React Starter App with ShadCN UI & CodeIgniter4 Shield Auth",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/shield": "^1.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
